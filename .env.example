# MakScore - configuracoes do modulo
# Estas variaveis nunca devem ser expostas ao frontend.

# Modo do conector E-POSI: "mock" (homologacao local) ou "live" (integracao real).
# Em "mock" o sistema NAO chama a E-POSI e marca explicitamente a resposta como mock.
MAKSCORE_EPOSI_MODE=mock

# Endpoints E-POSI (somente backend)
MAKSCORE_EPOSI_AUTH_URL=https://eposi.toolsdata.com.br/api/gatewaybiro/authentication
MAKSCORE_EPOSI_QUERY_URL=https://eposi.toolsdata.com.br/api/gatewaybiro/processfilter

# Credenciais E-POSI (somente backend, nunca commitar).
# IMPORTANTE: o login da ferramenta web E-POSI NAO e necessariamente o
# mesmo da API. Confirmar com a Makfil/E-POSI antes de usar credenciais
# da web aqui. Em duvida, manter MAKSCORE_EPOSI_MODE=mock.
MAKSCORE_EPOSI_LOGIN=
MAKSCORE_EPOSI_PASSWORD=

# Credencial SECUNDARIA (opcional) para rotacao sem downtime.
# Regras:
#  - Deixe AMBAS vazias se nao usar (compat total: so a primaria).
#  - Em producao+live, definir uma metade sem a outra FALHA o startup.
#  - Se primaria falhar autenticacao, o cliente cai para a secundaria.
MAKSCORE_EPOSI_LOGIN_SECONDARY=
MAKSCORE_EPOSI_PASSWORD_SECONDARY=

# Ordem de tentativa: "primary" (default) ou "secondary".
# Inverte qual credencial e tentada primeiro (cutover controlado).
# NUNCA desativa o fallback - apenas troca a ordem.
MAKSCORE_EPOSI_ACTIVE_CREDENTIAL=primary

# Produto padrao: TOTAL_PJ ou COMPLETA_PJ
MAKSCORE_DEFAULT_PRODUCT=TOTAL_PJ

# Politica Makfil (valores conservadores - revisar com area)
MAKSCORE_APPROVE_MIN_SCORE=700
MAKSCORE_REPROVE_MAX_SCORE=400
MAKSCORE_VALIDITY_HOURS=24

# Ticket pretendido (BRL): valor a partir do qual a operacao e considerada
# "alto ticket" e empurra cenarios intermediarios (score abaixo do limite,
# empresa recente R1, baixa info R0/R2) para `exige_analise`.
# Default conservador - pendente validacao comercial Makfil.
MAKSCORE_HIGH_TICKET_AMOUNT=50000

# Resiliencia
MAKSCORE_HTTP_TIMEOUT_MS=8000
MAKSCORE_RATE_LIMIT_PER_MIN=20

# Pepper para hash de CNPJ na persistencia (resumo). Definir em prod.
MAKSCORE_CNPJ_PEPPER=

# Autenticacao e sessao
# Gere hashes Argon2 com: npm run auth:hash -- "SuaSenhaForte123!"
AUTH_SESSION_SECRET=trocar-por-segredo-longo-e-aleatorio
AUTH_SESSION_COOKIE_NAME=hub_sid
AUTH_SESSION_TTL_MS=43200000
# Idle timeout: sessao expira se ficar inativa por N ms (sliding window).
# Default 30 min. 0 desabilita o idle timeout (so vale o TTL absoluto).
AUTH_SESSION_IDLE_MS=1800000
# Roles cuja sessao e amarrada ao IP de origem. Se o IP mudar, sessao
# e invalidada. Em producao default e "admin,analista"; vazio em dev/test.
AUTH_SESSION_BIND_IP_ROLES=admin,analista
# Cookie CSRF (nao HttpOnly, lido pelo SPA para preencher X-CSRF-Token).
AUTH_CSRF_COOKIE_NAME=hub_csrf
AUTH_SECURE_COOKIES=false
AUTH_TRUST_PROXY=true
AUTH_TRUSTED_ORIGINS=http://localhost:3000
AUTH_ALLOW_DEV_HEADER_AUTH=false

# Bootstrap de admin local
AUTH_BOOTSTRAP_ADMIN_ID=bootstrap-admin
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD_HASH=

# Opcional: lista JSON de usuarios internos
# AUTH_USERS_JSON=[{"id":"u1","username":"vendedor","role":"vendedor","passwordHash":"$argon2id$..."},{"id":"u2","username":"analista","role":"analista","passwordHash":"$argon2id$..."}]

# Rate limit
AUTH_USER_RATE_LIMIT_PER_MIN=60
AUTH_IP_RATE_LIMIT_PER_MIN=120
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10
AUTH_LOGIN_FAILURE_LIMIT_PER_15_MIN=25

# Politica de senha local
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SYMBOL=true

# Argon2id
AUTH_ARGON2_MEMORY_COST=19456
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_PARALLELISM=1

# MFA / TOTP
# Lista de papeis que precisam obrigatoriamente fazer enrollment de MFA.
# Em producao default e "admin,analista"; em dev/test default vazio.
# Usuarios desses papeis sem MFA recebem sessao em modo enrollmentPending,
# que so libera /api/auth/mfa/enroll e /api/auth/mfa/verify-enrollment.
AUTH_MFA_REQUIRED_ROLES=admin,analista
# Issuer exibido no app autenticador (Google Authenticator, Authy, 1Password, etc.)
AUTH_MFA_ISSUER=HubVendasMakfil
# TTL do challenge entre /login (passo 1) e /login/mfa (passo 2)
AUTH_MFA_CHALLENGE_TTL_MS=300000
# Codigos de recuperacao gerados no enrollment (mostrados ao usuario UMA vez)
AUTH_MFA_RECOVERY_CODES=10
# Rate limit de tentativas /login/mfa por IP, por minuto
AUTH_MFA_RATE_LIMIT_PER_MIN=5
# Falhas de TOTP por usuario antes de bloquear (janela de 15 min)
AUTH_MFA_FAILURE_LIMIT_PER_15_MIN=10

# Auditoria persistente
# Caminho do arquivo JSON Lines (JSONL) append-only. Cada linha e um
# evento de seguranca (login, MFA, sessao, CSRF). Em producao deixe o
# default ou aponte para volume persistente (ex: /var/log/hub-audit.jsonl).
# Definir vazio (AUDIT_LOG_PATH=) desativa file sink (so memoria + stdout).
# Em producao, deixar vazio ou omitir impede o startup.
AUDIT_LOG_PATH=./logs/security-audit.jsonl
# Quantos eventos manter em memoria para o endpoint admin /api/auth/audit/recent.
AUDIT_MEMORY_RETAIN=1000

# Estado distribuido (Redis)
# Sessoes, rate limits, challenges MFA e cache de token E-POSI sao
# estado efemero/operacional. Com REDIS_URL ficam compartilhados entre
# replicas e sobrevivem a restart. SEM REDIS_URL, caem para memoria
# (dev/test - perde no restart, nao escala horizontalmente).
REDIS_URL=
# Prefixo de chave (namespacing se o Redis for compartilhado).
REDIS_KEY_PREFIX=hubvendas:
# true se o Redis exigir TLS (Redis gerenciado).
REDIS_TLS=false
# OPT-OUT DE EMERGENCIA. Em NODE_ENV=production o startup FALHA se
# REDIS_URL estiver ausente. ALLOW_IN_MEMORY_STATE=true permite subir
# mesmo assim - uso APENAS emergencial/dev. Reduz a maturidade de
# seguranca: sessoes e rate limits nao sobrevivem a restart nem sao
# compartilhados entre instancias (rate limit efetivo ~ N x limite).
ALLOW_IN_MEMORY_STATE=false

# Servidor
PORT=3000
