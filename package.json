{
  "name": "hub-vendas-api",
  "version": "0.1.0",
  "private": true,
  "description": "HUB de Vendas Makfil - API backend (modulo MakScore isolado)",
  "type": "commonjs",
  "scripts": {
    "auth:hash": "ts-node src/scripts/hash-password.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/src/server.js",
    "dev": "node --env-file=.env -r ts-node/register src/server.ts",
    "dev:mock": "ts-node src/server.ts",
    "test": "node tests/test-loader.js"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "express": "^4.19.2",
    "ioredis": "5.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
